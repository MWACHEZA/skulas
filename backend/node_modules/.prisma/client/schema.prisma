datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Plan {
  id        String   @id @default(cuid())
  name      String   @unique // Starter, Professional, Enterprise
  price     Float
  features  String[] // e.g. ["ai_chat", "unlimited_students", "2gb_uploads"]
  schools   School[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model School {
  id             String          @id @default(cuid())
  code           String          @unique // AX-XXXXXX
  name           String
  type           String // primary, secondary, combined
  address        String?
  country        String?
  email          String          @unique
  phone          String?
  website        String?
  status         String          @default("trial") // trial, active, suspended
  planId         String
  plan           Plan            @relation(fields: [planId], references: [id])
  branding       Json? // { primaryColor, accentColor, logo }
  customContent  Json? // { motto, welcomeTitle, ... }
  users          User[]
  students       Student[]
  teachers       Teacher[]
  news           News[]
  gallery        Gallery[]
  clubs          Club[]
  sports         Sport[]
  applications   Application[]
  announcements  Announcement[]
  timetableSlots TimetableSlot[]
  classes        SchoolClass[]
  subjects       Subject[]
  books          Book[]
  tuckshopItems  TuckshopItem[]

  // Junctions
  suppliers      SchoolSupplier[]
  assets         Asset[]
  reportTemplate ReportTemplate?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  password       String
  name           String
  role           String // SUPER_ADMIN, SCHOOL_ADMIN, TEACHER, BURSAR, LIBRARIAN, STUDENT, ALUMNI, ANCILLARY, PARENT, SUPPLIER
  secondaryRoles String[] @default([])
  avatar         String? // Stores filename or reference ID

  phone            String?
  staffId          String? // Unique sequential ID (BUR-YY000001, etc.)
  schoolId         String?
  school           School?           @relation(fields: [schoolId], references: [id])
  teacher          Teacher?
  student          Student?
  parent           Parent?
  supplier         Supplier?
  salaryStubs      SalaryStub[]
  shiftAssignments ShiftAssignment[]

  assignedAssets    Asset[]          @relation("AssetCustodian")
  reportedIncidents AssetIncident[]  @relation("IncidentReporter")
  supportTickets    SupportTicket[]  @relation("SupportRequester")
  reports           AcademicReport[]

  metadata            Json? // Role-specific data
  isLocked            Boolean  @default(false)
  mustChangePassword  Boolean  @default(false)
  passwordLastChanged DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([schoolId])
}

model Teacher {
  id            String            @id @default(cuid())
  staffId       String
  userId        String            @unique
  user          User              @relation(fields: [userId], references: [id])
  schoolId      String
  school        School            @relation(fields: [schoolId], references: [id])
  qualification String?
  department    String?
  classes       SchoolClass[]
  subjects      TeacherSubject[]
  grades        Grade[]
  assignments   Assignment[]
  attendance    Attendance[]
  resources     DigitalResource[]
  lessonPlans   LessonPlan[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([schoolId, staffId])
  @@index([schoolId])
}

model Student {
  id         String       @id @default(cuid())
  studentId  String // School-specific ID e.g. STU-0001
  name       String
  userId     String?      @unique
  user       User?        @relation(fields: [userId], references: [id])
  email      String?
  phone      String?
  dob        DateTime?
  gender     String?
  address    String?
  classId    String?
  class      SchoolClass? @relation(fields: [classId], references: [id])
  schoolId   String
  school     School       @relation(fields: [schoolId], references: [id])
  grades     Grade[]
  attendance Attendance[]
  fees       Fee[]
  bookLoans  BookLoan[]

  // Relationships
  parents ParentStudent[]

  status    String   @default("Enrolled") // Enrolled, Suspended, Inactive
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, studentId])
  @@index([schoolId])
}

model SchoolClass {
  id             String          @id @default(cuid())
  name           String // e.g. "Form 3A", "Upper 6 Science"
  level          String // Form 1, Form 2 ... Upper 6
  teacherId      String?
  teacher        Teacher?        @relation(fields: [teacherId], references: [id])
  schoolId       String
  school         School          @relation(fields: [schoolId], references: [id])
  students       Student[]
  timetableSlots TimetableSlot[]

  @@index([schoolId])
}

model Subject {
  id             String            @id @default(cuid())
  name           String
  code           String?
  department     String?
  schoolId       String
  school         School            @relation(fields: [schoolId], references: [id])
  teachers       TeacherSubject[]
  grades         Grade[]
  assignments    Assignment[]
  timetableSlots TimetableSlot[]
  resources      DigitalResource[]
  lessonPlans    LessonPlan[]

  @@index([schoolId])
}

model TeacherSubject {
  id        String  @id @default(cuid())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, subjectId])
}

model Grade {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id])
  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  term      String // Term 1, Term 2, Term 3
  year      Int
  score     Float
  maxScore  Float    @default(100)
  grade     String // A, B, C ...
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([subjectId])
}

model Attendance {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id])
  date      DateTime
  status    String // present, absent, late, excused
  note      String?
  createdAt DateTime @default(now())

  @@index([studentId])
  @@index([date])
}

model Fee {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  term        String
  year        Int
  amount      Float
  paid        Float    @default(0)
  dueDate     DateTime
  status      String   @default("unpaid") // paid, partial, unpaid, overdue
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([studentId])
}

model Assignment {
  id          String   @id @default(cuid())
  title       String
  description String?
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  dueDate     DateTime
  maxScore    Float    @default(100)
  status      String   @default("active") // active, closed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([subjectId])
  @@index([teacherId])
}

model TimetableSlot {
  id        String      @id @default(cuid())
  classId   String
  class     SchoolClass @relation(fields: [classId], references: [id])
  subjectId String
  subject   Subject     @relation(fields: [subjectId], references: [id])
  schoolId  String
  school    School      @relation(fields: [schoolId], references: [id])
  dayOfWeek Int // 1=Mon ... 5=Fri
  startTime String // "08:00"
  endTime   String // "09:00"
  room      String?

  @@index([classId])
  @@index([schoolId])
}

model Announcement {
  id          String    @id @default(cuid())
  title       String
  content     String
  targetRole  String    @default("ALL") // ALL, STUDENT, TEACHER, BURSAR, ...
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id])
  publishedAt DateTime  @default(now())
  expiresAt   DateTime?

  @@index([schoolId])
}

model Book {
  id        String     @id @default(cuid())
  title     String
  author    String
  isbn      String?
  category  String?
  copies    Int        @default(1)
  available Int        @default(1)
  schoolId  String
  school    School     @relation(fields: [schoolId], references: [id])
  loans     BookLoan[]
  createdAt DateTime   @default(now())

  @@index([schoolId])
}

model BookLoan {
  id         String    @id @default(cuid())
  bookId     String
  book       Book      @relation(fields: [bookId], references: [id])
  studentId  String
  student    Student   @relation(fields: [studentId], references: [id])
  borrowedAt DateTime  @default(now())
  dueDate    DateTime
  returnedAt DateTime?
  status     String    @default("borrowed") // borrowed, returned, overdue

  @@index([studentId])
  @@index([bookId])
}

model News {
  id          String   @id @default(cuid())
  title       String
  content     String
  image       String?
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  publishedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId])
}

model Gallery {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
}

model Club {
  id          String  @id @default(cuid())
  name        String
  description String?
  icon        String?
  schoolId    String
  school      School  @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model Sport {
  id          String  @id @default(cuid())
  name        String
  description String?
  icon        String?
  schoolId    String
  school      School  @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model Application {
  id            String              @id @default(cuid())
  applicantName String
  email         String
  phone         String?
  dob           DateTime?
  gender        String?
  appType       String              @default("Form 1") // Form 1, A-Level, Transfer
  status        String              @default("pending") // pending, accepted, rejected, waitlisted
  schoolId      String
  school        School              @relation(fields: [schoolId], references: [id])
  notes         String?
  documents     ApplicantDocument[]
  timeline      ApplicantTimeline[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([schoolId])
}

// ═══════════ SUPPLIER / PROCUREMENT ═══════════

model Supplier {
  id           String  @id @default(cuid())
  globalId     String? @unique // SUP-GLB-XXXXXX
  companyName  String
  contactName  String
  email        String  @unique
  phone        String?
  address      String?
  taxClearance String? // cert number
  prazCert     String? // PRAZ registration
  status       String  @default("active") // active, suspended, blacklisted
  userId       String? @unique
  user         User?   @relation(fields: [userId], references: [id])

  // Junctions
  schools SchoolSupplier[]

  tenders        TenderBid[]
  purchaseOrders PurchaseOrder[]
  invoices       Invoice[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model SchoolSupplier {
  id               String   @id @default(cuid())
  schoolSpecificId String? // SUP-AX-XXXXXX
  schoolId         String
  school           School   @relation(fields: [schoolId], references: [id])
  supplierId       String
  supplier         Supplier @relation(fields: [supplierId], references: [id])
  status           String   @default("PENDING") // PENDING, APPROVED, REJECTED
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([schoolId, supplierId])
  @@index([schoolId])
}

// ═══════════ PARENT REGISTRY ═══════════

model Parent {
  id         String  @id @default(cuid())
  globalId   String? @unique // PAR-GLB-XXXXXX
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id])
  phone      String?
  address    String?
  occupation String?
  employer   String?

  // Junctions
  students ParentStudent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ParentStudent {
  id             String   @id @default(cuid())
  parentId       String
  parent         Parent   @relation(fields: [parentId], references: [id])
  studentId      String
  student        Student  @relation(fields: [studentId], references: [id])
  relation       String   @default("Guardian") // Father, Mother, Guardian, etc.
  isPrimaryPayer Boolean  @default(false)
  status         String   @default("APPROVED") // Usually auto-approved if student pass matches
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([parentId, studentId])
  @@index([parentId])
  @@index([studentId])
}

model Tender {
  id          String      @id @default(cuid())
  title       String
  description String
  category    String // goods, services, works
  budget      Float?
  openDate    DateTime    @default(now())
  closeDate   DateTime
  status      String      @default("open") // open, closed, awarded, cancelled
  schoolId    String
  bids        TenderBid[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([schoolId])
}

model TenderBid {
  id          String   @id @default(cuid())
  tenderId    String
  tender      Tender   @relation(fields: [tenderId], references: [id])
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  amount      Float
  proposal    String?
  status      String   @default("submitted") // submitted, shortlisted, awarded, rejected
  submittedAt DateTime @default(now())

  @@unique([tenderId, supplierId])
}

model PurchaseOrder {
  id          String   @id @default(cuid())
  poNumber    String   @unique
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  description String
  items       Json // [{name, qty, unitPrice}]
  totalAmount Float
  status      String   @default("draft") // draft, approved, delivered, cancelled
  schoolId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId])
}

model Invoice {
  id         String   @id @default(cuid())
  invoiceNo  String   @unique
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  amount     Float
  status     String   @default("pending") // pending, approved, paid, rejected
  dueDate    DateTime
  schoolId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([schoolId])
}

// ═══════════ MESSAGING ═══════════

model Message {
  id          String   @id @default(cuid())
  senderId    String
  recipientId String
  subject     String
  body        String
  isRead      Boolean  @default(false)
  schoolId    String
  createdAt   DateTime @default(now())

  @@index([recipientId])
  @@index([schoolId])
}

// ═══════════ IT SUPPORT TICKETS ═══════════

model SupportTicket {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String // hardware, software, network, other
  priority    String   @default("medium") // low, medium, high, urgent
  status      String   @default("open") // open, in_progress, resolved, closed
  requesterId String
  requester   User     @relation("SupportRequester", fields: [requesterId], references: [id])
  assignedTo  String?
  schoolId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId])
  @@index([requesterId])
}

// ═══════════ STAFF LEAVE / HR ═══════════

model StaffLeave {
  id         String   @id @default(cuid())
  userId     String
  leaveType  String // annual, sick, maternity, study, unpaid
  startDate  DateTime
  endDate    DateTime
  reason     String?
  status     String   @default("pending") // pending, approved, rejected
  approvedBy String?
  schoolId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([schoolId])
}

// ═══════════ ASSET INVENTORY ═══════════

model Asset {
  id            String    @id @default(cuid())
  name          String
  category      String // furniture, electronics, vehicles, stationery
  serialNumber  String?
  location      String?
  condition     String    @default("good") // good, fair, poor, condemned
  purchaseDate  DateTime?
  purchasePrice Float?

  custodianId String?
  custodian   User?   @relation("AssetCustodian", fields: [custodianId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  incidents   AssetIncident[]
  maintenance AssetMaintenance[]

  nextMaintenance DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([custodianId])
}

model AssetIncident {
  id         String @id @default(cuid())
  assetId    String
  asset      Asset  @relation(fields: [assetId], references: [id])
  reporterId String
  reporter   User   @relation("IncidentReporter", fields: [reporterId], references: [id])

  issueType String // general, hardware, usage, theft
  details   String
  status    String @default("PENDING") // PENDING, RESOLVED

  resolvedBy String?
  fixDetails String?

  schoolId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
  @@index([reporterId])
}

model AssetMaintenance {
  id      String @id @default(cuid())
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  scheduledDate DateTime
  performedDate DateTime?
  description   String
  cost          Float?

  schoolId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
}

// ═══════════ TRANSPORT ═══════════

model TransportRoute {
  id          String   @id @default(cuid())
  name        String
  description String?
  driverName  String?
  driverPhone String?
  vehicle     String? // e.g. "Bus 1 - Reg ABC 1234"
  stops       Json? // [{name, time}]
  schoolId    String
  createdAt   DateTime @default(now())

  @@index([schoolId])
}

// ═══════════ EVENTS ═══════════

model SchoolEvent {
  id          String    @id @default(cuid())
  title       String
  description String?
  date        DateTime
  endDate     DateTime?
  venue       String?
  category    String    @default("general") // general, sports, academic, social
  schoolId    String
  createdAt   DateTime  @default(now())

  @@index([schoolId])
}

// ═══════════ TUCKSHOP / RETAIL ═══════════

model TuckshopItem {
  id        String         @id @default(cuid())
  name      String
  category  String // Uniform, Stationery, Snack, Drink
  price     Float
  stock     Int            @default(0)
  schoolId  String
  school    School         @relation(fields: [schoolId], references: [id])
  sales     TuckshopSale[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([schoolId])
}

model TuckshopSale {
  id          String       @id @default(cuid())
  itemId      String
  item        TuckshopItem @relation(fields: [itemId], references: [id])
  quantity    Int
  totalAmount Float
  soldAt      DateTime     @default(now())
  studentId   String? // Optional: link to student if recorded
  schoolId    String

  @@index([schoolId])
}

// ═══════════ ACADEMIC CONTENT ═══════════

model DigitalResource {
  id          String   @id @default(cuid())
  title       String
  description String?
  fileUrl     String
  fileType    String // PDF, Video, Link, Doc
  category    String // Syllabus, Lecture Note, Past Paper
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  schoolId    String
  createdAt   DateTime @default(now())

  @@index([teacherId])
  @@index([subjectId])
}

model LessonPlan {
  id         String   @id @default(cuid())
  title      String
  content    String // Objectives, Materials, Procedure
  weekNumber Int
  term       String
  year       Int
  teacherId  String
  teacher    Teacher  @relation(fields: [teacherId], references: [id])
  subjectId  String
  subject    Subject  @relation(fields: [subjectId], references: [id])
  schoolId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([teacherId])
  @@index([subjectId])
}

// ═══════════ HR / PAYROLL / ROSTERS ═══════════

model SalaryStub {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  month      Int
  year       Int
  basicPay   Float
  allowances Float     @default(0)
  deductions Float     @default(0)
  netPay     Float
  status     String    @default("draft") // draft, paid
  paidAt     DateTime?
  schoolId   String
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([schoolId])
}

model ShiftAssignment {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  dayOfWeek Int // 0=Sun ... 6=Sat
  startTime String // "06:00"
  endTime   String // "14:00"
  location  String?
  task      String?
  schoolId  String

  @@index([userId])
  @@index([schoolId])
}

// ═══════════ APPLICANT PORTAL DEPTH ═══════════

model ApplicantDocument {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  name          String // e.g. "Birth Certificate"
  url           String
  status        String      @default("pending") // pending, verified, rejected
  createdAt     DateTime    @default(now())

  @@index([applicationId])
}

model ApplicantTimeline {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  event         String // Application Submitted, Interview Scheduled, Accepted
  description   String?
  occurredAt    DateTime    @default(now())

  @@index([applicationId])
}

// --- ACADEMIC REPORTING ---

model AcademicReport {
  id               String   @id @default(cuid())
  studentId        String
  student          User     @relation(fields: [studentId], references: [id])
  term             String // Term 1, Term 2, Term 3
  year             String // e.g. "2024"
  data             Json // Snapshot of grades, attendance, comments
  publishedStudent Boolean  @default(false)
  publishedParent  Boolean  @default(false)
  schoolId         String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([studentId])
  @@index([schoolId])
}

model ReportTemplate {
  id           String   @id @default(cuid())
  schoolId     String   @unique
  school       School   @relation(fields: [schoolId], references: [id])
  config       Json // Branding colors, section toggles
  signatureUrl String? // Principal/Headmaster signature
  updatedAt    DateTime @updatedAt
}
