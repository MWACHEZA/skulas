datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

model Plan {
  id        String   @id @default(cuid())
  name      String   @unique // Starter, Professional, Enterprise
  price     Float
  features  String[] // e.g. ["ai_chat", "unlimited_students", "2gb_uploads"]
  schools   School[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model School {
  id                    String                 @id @default(cuid())
  code                  String                 @unique // AX-XXXXXX
  name                  String
  type                  String // primary, secondary, combined
  isCombined            Boolean                @default(false)
  levels                String[] // ["PRE_SCHOOL", "PRIMARY", "SECONDARY", "HIGH_SCHOOL", "TERTIARY"]
  address               String?
  country               String?
  email                 String                 @unique
  phone                 String?
  website               String?
  status                String                 @default("active")
  planId                String
  plan                  Plan                   @relation(fields: [planId], references: [id])
  branding              Json? // { primaryColor, accentColor, logo }
  customContent         Json? // { motto, welcomeTitle, ... }
  users                 User[]
  students              Student[]
  teachers              Teacher[]
  news                  News[]
  websiteInquiries      WebsiteInquiry[]
  noticeboards          Noticeboard[]
  vacancies             Vacancy[]
  jobApplications       JobApplication[]
  gallery               Gallery[]
  clubs                 Club[]
  sports                Sport[]
  applications          Application[]
  announcements         Announcement[]
  chaplaincyEvents      ChaplaincyEvent[]
  diningHallReports     DiningHallReport[]
  farmLivestockBatches  FarmLivestockBatch[]
  farmCropCycles        FarmCropCycle[]
  farmInventoryItems    FarmInventoryItem[]
  prefectDuties         PrefectDuty[]
  prefectMeetings       PrefectMeeting[]
  prefectReports        PrefectReport[]
  staffAttendances      StaffAttendance[]
  timetableSlots        TimetableSlot[]
  classes               SchoolClass[]
  subjects              Subject[]
  books                 Book[]
  grades                Grade[]
  attendance            Attendance[]
  fees                  Fee[]
  assignments           Assignment[]
  bookLoans             BookLoan[]
  assignmentSubmissions AssignmentSubmission[]
  supervisorAssignments SupervisorAssignment[]
  extensionRequests     ExtensionRequest[]
  progressReports       ProgressReport[]
  tuckshopItems         TuckshopItem[]

  // Junctions
  suppliers       SchoolSupplier[]
  assets          Asset[]
  reportTemplate  ReportTemplate?
  websiteSettings WebsiteSettings?
  requisitions    Requisition[]
  auditLogs       AuditLog[]
  departments     Department[]
  hostels         Hostel[]
  weeklyMenus     WeeklyMenu[]

  originTransfers TransferAuthorization[] @relation("OriginTransfers")
  targetTransfers TransferAuthorization[] @relation("TargetTransfers")

  hexcoCenterNumber String? // Optional for Polytechnics

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  idCardTemplate              String? // Path to ID card template image
  settings                    Json? // Institutional settings (SMTP, WhatsApp, Currencies, etc.)
  faculties                   Faculty[]
  paymentMethods              PaymentMethod[]
  feeGroups                   FeeGroup[]
  revenueAllocations          RevenueAllocation[]
  allowanceTypes              PayrollAllowance[]
  deductionTypes              PayrollDeduction[]
  taxTables                   TaxTable[]
  employeeProfiles            EmployeeProfile[]
  accountCategories           AccountCategory[]
  liabilities                 Liability[]
  incomes                     Income[]
  expenses                    Expense[]
  uniformItems                UniformItem[]
  uniformStockOrders          UniformStockOrder[]
  uniformSales                UniformSale[]
  uniformSupplierPayments     UniformSupplierPayment[]
  physicalProducts            PhysicalProduct[]
  physicalProductConsumptions PhysicalProductConsumption[]
  feeReminderLogs             FeeReminderLog[]
  termlyComments              TermlyComment[]
  payrollRuns                 PayrollRun[]
  questionPapers              QuestionPaper[]
  payrollEntries              PayrollEntry[]

  gradingScales GradingScale[]

  studentPayments   StudentPayment[]
  communicationLogs CommunicationLog[]

  libraryCategories LibraryCategory[]
  sections          Section[]
  studentHouses     StudentHouse[]
  holidays          Holiday[]
  schoolSetting     SchoolSetting?
  CBTExam           CBTExam[]
  Syllabus          Syllabus[]
  LessonPlan        LessonPlan[]
  LiveClass         LiveClass[]
  Award             Award[]
  Course            Course[]
  StudyMaterial     StudyMaterial[]
  hostelCategories  HostelCategory[]
  hostelRooms       HostelRoom[]
  SchoolVehicle     SchoolVehicle[]
  SchoolTransport   SchoolTransport[]
  paymentPlans      PaymentPlan[]
  meetingMinutes    MeetingMinutes[]
  projectFundings   ProjectFunding[]
  sportingEquipment SportingEquipment[]

  @@index([code])
}

model GradingScale {
  id        String   @id @default(cuid())
  grade     String // e.g. A+, B, C
  minScore  Int // e.g. 80
  maxScore  Int // e.g. 100
  status    String // e.g. PASS, FAIL, DISTINCTION
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
}

model HostelCategory {
  id          String   @id @default(cuid())
  name        String
  description String?
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  hostels     Hostel[]
  createdAt   DateTime @default(now())
}

model HostelRoom {
  id           String   @id @default(cuid())
  name         String
  type         String
  numberOfBeds Int
  cost         Float
  description  String?
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id])
  hostels      Hostel[]
  createdAt    DateTime @default(now())
}

// ... (other models)

model UniformItem {
  id           String                  @id @default(cuid())
  name         String
  orderPrice   Float                   @default(0)
  sellingPrice Float                   @default(0)
  stockLevel   Int                     @default(0)
  schoolId     String
  school       School                  @relation(fields: [schoolId], references: [id])
  stockItems   UniformStockOrderItem[]
  saleItems    UniformSaleItem[]
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@index([schoolId])
}

model UniformStockOrder {
  id             String                  @id @default(cuid())
  orderDate      DateTime                @default(now())
  supplierId     String?
  supplier       Supplier?               @relation(fields: [supplierId], references: [id])
  paymentMode    String?
  reference      String?
  totalAmount    Float                   @default(0)
  initialPayment Float                   @default(0)
  schoolId       String
  school         School                  @relation(fields: [schoolId], references: [id])
  items          UniformStockOrderItem[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  @@index([schoolId])
}

model UniformStockOrderItem {
  id        String            @id @default(cuid())
  orderId   String
  order     UniformStockOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemId    String
  item      UniformItem       @relation(fields: [itemId], references: [id])
  quantity  Int
  unitPrice Float
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model UniformSale {
  id          String            @id @default(cuid())
  saleDate    DateTime          @default(now())
  studentId   String?
  student     Student?          @relation(fields: [studentId], references: [id])
  parentId    String?
  parent      Parent?           @relation(fields: [parentId], references: [id])
  paymentMode String?
  reference   String?
  totalAmount Float             @default(0)
  schoolId    String
  school      School            @relation(fields: [schoolId], references: [id])
  items       UniformSaleItem[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([schoolId])
}

model UniformSaleItem {
  id        String      @id @default(cuid())
  saleId    String
  sale      UniformSale @relation(fields: [saleId], references: [id], onDelete: Cascade)
  itemId    String
  item      UniformItem @relation(fields: [itemId], references: [id])
  quantity  Int
  unitPrice Float
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model UniformSupplierPayment {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  amount      Float
  date        DateTime @default(now())
  paymentMode String?
  reference   String?
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId])
}

model AccountCategory {
  id          String      @id @default(cuid())
  name        String
  type        String // INCOME, EXPENSE, LIABILITY
  schoolId    String
  school      School      @relation(fields: [schoolId], references: [id])
  incomes     Income[]
  expenses    Expense[]
  liabilities Liability[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([schoolId, name, type])
  @@index([schoolId])
}

model Liability {
  id         String          @id @default(cuid())
  name       String
  categoryId String
  category   AccountCategory @relation(fields: [categoryId], references: [id])
  amount     Float
  settled    Float           @default(0)
  date       DateTime        @default(now())
  status     String          @default("Unsettled") // Unsettled, Partially Settled, Settled
  schoolId   String
  school     School          @relation(fields: [schoolId], references: [id])
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([schoolId])
}

model Income {
  id          String          @id @default(cuid())
  title       String
  amount      Float
  categoryId  String
  category    AccountCategory @relation(fields: [categoryId], references: [id])
  date        DateTime        @default(now())
  paymentMode String?
  currency    String          @default("USD")
  schoolId    String
  school      School          @relation(fields: [schoolId], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([schoolId])
}

model Expense {
  id          String          @id @default(cuid())
  title       String
  amount      Float
  categoryId  String
  category    AccountCategory @relation(fields: [categoryId], references: [id])
  date        DateTime        @default(now())
  paymentMode String?
  currency    String          @default("USD")
  schoolId    String
  school      School          @relation(fields: [schoolId], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([schoolId])
}

model User {
  recruitedVacancies Vacancy[]
  id                 String        @id @default(cuid())
  email              String        @unique
  password           String
  name               String
  role               String // SUPER_ADMIN, SCHOOL_ADMIN, TEACHER, BURSAR, LIBRARIAN, STUDENT, ALUMNI, ANCILLARY, PARENT, SUPPLIER
  secondaryRoles     String[]      @default([])
  sessions           UserSession[]
  avatar             String? // Stores filename or reference ID
  religion           String? // User's religious affiliation

  phone             String?
  preferredLanguage String?           @default("en")
  staffId           String? // Unique sequential ID (BUR-YY000001, etc.)
  schoolId          String?
  school            School?           @relation(fields: [schoolId], references: [id])
  teacher           Teacher?
  student           Student?
  parent            Parent?
  supplier          Supplier?
  salaryStubs       SalaryStub[]
  shiftAssignments  ShiftAssignment[]
  employeeProfile   EmployeeProfile?
  awards            Award[]
  courses           Course[]
  bookLoans         BookLoan[]

  departmentId String?
  dept         Department? @relation(fields: [departmentId], references: [id])

  headedDepartments Department[] @relation("DeptHead")

  // Ancillary Roles
  authorizedBoardingLogs BoardingLog[]
  visitorLogs            VisitorLog[]
  securityIncidents      SecurityIncident[]
  auditLogs              AuditLog[]
  diningHallReports      DiningHallReport[]
  prefectReports         PrefectReport[]

  assignedAssets             Asset[]                 @relation("AssetCustodian")
  assignedSportingEquipments SportingEquipment[]     @relation("EquipmentCustodian")
  reportedIncidents          AssetIncident[]         @relation("IncidentReporter")
  supportTickets             SupportTicket[]         @relation("SupportRequester")
  reports                    AcademicReport[]
  requisitions               Requisition[]           @relation("RequisitionRequester")
  hodRequisitions            Requisition[]           @relation("RequisitionHOD")
  bursarRequisitions         Requisition[]           @relation("RequisitionBursar")
  adminRequisitions          Requisition[]           @relation("RequisitionAdmin")
  transfers                  TransferAuthorization[] @relation("StudentTransfers")

  communicationLogs CommunicationLog[] @relation("CommunicationSender")

  metadata            Json? // Role-specific data
  isLocked            Boolean  @default(false)
  mustChangePassword  Boolean  @default(false)
  passwordLastChanged DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  staffAttendances StaffAttendance[]
  LiveClass        LiveClass[]
  StudyMaterial    StudyMaterial[]
  paymentPlans     PaymentPlan[]     @relation("ParentPaymentPlans")
  payrollEntries   PayrollEntry[]

  clinicAppointments  ClinicAppointment[]
  clinicComplaints    ClinicComplaint[]
  clinicImmunizations ClinicImmunization[]
  clinicReferrals     ClinicReferral[]

  @@index([schoolId])
}

model UserSession {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenFamily  String? // Optional: For grouping/refresh flows later
  ipAddress    String?
  userAgent    String?
  deviceInfo   String? // Optional parsed user-agent
  isValid      Boolean  @default(true)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now())

  @@index([userId])
}

model Teacher {
  id             String                 @id @default(cuid())
  staffId        String
  userId         String                 @unique
  user           User                   @relation(fields: [userId], references: [id])
  schoolId       String
  school         School                 @relation(fields: [schoolId], references: [id])
  qualification  String?
  title          String? // e.g. Prof., Dr., Mr.
  department     String? // Keep for legacy/string-based fallback
  departmentId   String?
  dept           Department?            @relation(fields: [departmentId], references: [id])
  classes        SchoolClass[]
  subjects       TeacherSubject[]
  subjectClasses ClassSubjectTeacher[]
  grades         Grade[]
  assignments    Assignment[]
  attendance     Attendance[]
  resources      DigitalResource[]
  lessonPlans    LessonPlan[]
  supervisions   SupervisorAssignment[]
  questionPapers QuestionPaper[]
  houseMastered  StudentHouse[]         @relation("HouseMaster")
  textbooks      Book[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@unique([schoolId, staffId])
  @@index([schoolId])
}

model Student {
  id                String                 @id @default(cuid())
  studentId         String // School-specific ID e.g. STU-0001
  name              String
  userId            String?                @unique
  user              User?                  @relation(fields: [userId], references: [id])
  email             String?
  phone             String?
  dob               DateTime?
  gender            String?
  preferredLanguage String?                @default("en")
  address           String?
  classId           String?
  class             SchoolClass?           @relation(fields: [classId], references: [id])
  schoolId          String
  school            School                 @relation(fields: [schoolId], references: [id])
  grades            Grade[]
  attendance        Attendance[]
  fees              Fee[]
  bookLoans         BookLoan[]
  submissions       AssignmentSubmission[]
  courseEnrollments CourseEnrollment[]

  // Postgraduate Fields
  programLevel      String?   @default("UNDERGRADUATE") // UNDERGRADUATE, PG_DIPLOMA, MASTERS_TAUGHT, MASTERS_RESEARCH, MPHIL, PHD
  studyMode         String?   @default("FULL_TIME") // FULL_TIME, PART_TIME
  researchTitle     String?
  startDate         DateTime? @default(now())
  maxCompletionDate DateTime?
  extensionMonths   Int       @default(0)

  // Relationships
  parents           ParentStudent[]
  supervisors       SupervisorAssignment[]
  extensionRequests ExtensionRequest[]
  progressReports   ProgressReport[]

  status         String        @default("Enrolled") // Enrolled, Suspended, Inactive
  standing       String        @default("Normal") // Normal, Carry, Repeat, Discontinue, Withdraw
  part           Int           @default(1) // Year of Study (Part I, II, III...)
  enrolledAt     DateTime      @default(now())
  guardianName   String?
  boardingStatus String        @default("Day") // Day, Boarder
  roomId         String?
  room           Room?         @relation(fields: [roomId], references: [id])
  hostelId       String?
  hostel         Hostel?       @relation(fields: [hostelId], references: [id])
  boardingLogs   BoardingLog[]

  // Previous Academic History (carried from application)
  prevSchool        String?
  reasonForTransfer String?
  lastGradeAchieved String?
  admissionsNotes   String?
  academicHistory   Json?
  enrollmentDate    DateTime? @default(now())

  hexcoId         String? // National HEXCO ID for Polytechnic students
  uniformSales    UniformSale[]
  feeReminderLogs FeeReminderLog[]
  termlyComments  TermlyComment[]

  houseId String?
  house   StudentHouse? @relation(fields: [houseId], references: [id])

  // New Registration Fields
  motherTongue            String?
  nationality             String?
  city                    String?
  state                   String?
  prevSchoolClass         String?
  prevSchoolAddress       String?
  hasTransferCertificate  Boolean @default(false)
  transferCertificateUrl  String?
  isPhysicallyHandicapped Boolean @default(false)
  handicapDetails         String?
  category                String? // General, Special, etc.
  section                 String?
  dormitory               String?
  birthCertificateUrl     String?
  age                     Int?

  clubId String?
  club   Club?   @relation(fields: [clubId], references: [id])

  payments          StudentPayment[]
  communicationLogs CommunicationLog[]
  paymentPlans      PaymentPlan[]
  houseCaptained    StudentHouse[]     @relation("HouseCaptain")
  wallet            StudentWallet?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, studentId])
  @@index([schoolId])
}

model SchoolClass {
  id                  String                @id @default(cuid())
  name                String // e.g. "Form 3A", "Upper 6 Science"
  level               String // Form 1, Form 2 ... Upper 6
  capacity            Int?
  sectionId           String?
  section             Section?              @relation(fields: [sectionId], references: [id])
  teacherId           String?
  teacher             Teacher?              @relation(fields: [teacherId], references: [id])
  schoolId            String
  school              School                @relation(fields: [schoolId], references: [id])
  students            Student[]
  attendances         Attendance[]
  timetableSlots      TimetableSlot[]
  subjectTeachers     ClassSubjectTeacher[]
  assignments         Assignment[]
  books               Book[]
  CBTExam             CBTExam[]
  Syllabus            Syllabus[]
  LessonPlan          LessonPlan[]
  LiveClass           LiveClass[]
  Course              Course[]
  StudyMaterial       StudyMaterial[]
  FeeGroupClassAmount FeeGroupClassAmount[]
  AdmissionInquiry    AdmissionInquiry[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Section {
  id        String        @id @default(cuid())
  name      String // Morning, Afternoon, Evening, Section A, Section B
  schoolId  String
  school    School        @relation(fields: [schoolId], references: [id])
  classes   SchoolClass[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  CBTExam   CBTExam[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Subject {
  id             String                @id @default(cuid())
  name           String
  code           String?
  department     String? // Keep for legacy/string-based fallback
  departmentId   String?
  dept           Department?           @relation(fields: [departmentId], references: [id])
  schoolId       String
  school         School                @relation(fields: [schoolId], references: [id])
  teachers       TeacherSubject[]
  classTeachers  ClassSubjectTeacher[]
  grades         Grade[]
  assignments    Assignment[]
  questionPapers QuestionPaper[]
  timetableSlots TimetableSlot[]
  resources      DigitalResource[]
  lessonPlans    LessonPlan[]
  books          Book[]

  gradingType   String          @default("standard") // standard or competency
  credits       Float?          @default(0)
  isIndustrial  Boolean         @default(false)
  isProject     Boolean         @default(false)
  isSubsidiary  Boolean         @default(false)
  caWeight      Float           @default(30)
  examWeight    Float           @default(70)
  CBTExam       CBTExam[]
  Syllabus      Syllabus[]
  StudyMaterial StudyMaterial[]

  @@index([schoolId])
}

model TeacherSubject {
  id        String  @id @default(cuid())
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, subjectId])
}

model ClassSubjectTeacher {
  id        String      @id @default(cuid())
  classId   String
  class     SchoolClass @relation(fields: [classId], references: [id])
  subjectId String
  subject   Subject     @relation(fields: [subjectId], references: [id])
  teacherId String
  teacher   Teacher     @relation(fields: [teacherId], references: [id])

  @@unique([classId, subjectId, teacherId])
  @@index([classId])
  @@index([subjectId])
  @@index([teacherId])
}

model Grade {
  id                String   @id @default(cuid())
  studentId         String
  student           Student  @relation(fields: [studentId], references: [id])
  subjectId         String
  subject           Subject  @relation(fields: [subjectId], references: [id])
  teacherId         String
  teacher           Teacher  @relation(fields: [teacherId], references: [id])
  term              String // Term 1, Term 2, Term 3
  year              Int
  score             Float
  maxScore          Float    @default(100)
  caScore           Float? // Continuous Assessment Score
  examScore         Float? // Examination Score
  grade             String // A, B, C ...
  industrialScores  Json? // { industrialSup: number, academicSup: number, report: number, oral: number }
  isIndustrialGrade Boolean  @default(false)
  gradePoint        Float? // Calculated points (e.g. 4.0, 3.0) for GPA
  comment           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, studentId, subjectId, term, year])
  @@index([schoolId])
  @@index([studentId])
  @@index([subjectId])
  @@index([schoolId, term, year])
}

model Faculty {
  id        String       @id @default(cuid())
  name      String
  schoolId  String
  school    School       @relation(fields: [schoolId], references: [id])
  depts     Department[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Department {
  vacancies Vacancy[]
  id        String    @id @default(cuid())
  name      String
  code      String? // e.g. SCI001
  deptCode  String? // 3-letter prefix (e.g. SCS)
  duration  Int       @default(4) // Program length in years
  schoolId  String
  school    School    @relation(fields: [schoolId], references: [id])
  facultyId String?
  faculty   Faculty?  @relation(fields: [facultyId], references: [id])
  teachers  Teacher[]
  subjects  Subject[]
  users     User[]

  headId String?
  head   User?   @relation("DeptHead", fields: [headId], references: [id])

  requisitions Requisition[]

  services   String?
  facilities String?
  pictures   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Attendance {
  id         String       @id @default(cuid())
  studentId  String
  student    Student      @relation(fields: [studentId], references: [id])
  teacherId  String
  teacher    Teacher      @relation(fields: [teacherId], references: [id])
  date       DateTime
  status     String // present, absent, late, excused
  note       String?
  scanMethod String? // e.g. Manual, QR Code
  classId    String? // Null for gate/global attendance
  class      SchoolClass? @relation(fields: [classId], references: [id])
  createdAt  DateTime     @default(now())
  schoolId   String
  school     School       @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, studentId, date, classId])
  @@index([schoolId])
  @@index([studentId])
  @@index([date])
  @@index([schoolId, date])
}

model StaffAttendance {
  id       String @id @default(cuid())
  staffId  String
  staff    User   @relation(fields: [staffId], references: [id])
  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  date    DateTime  @db.Date
  timeIn  DateTime?
  timeOut DateTime?
  status  String    @default("FULL DAY") // FULL DAY, HALF DAY, ABSENT, ON LEAVE

  clockInImage  String? // Base64 or URL
  clockOutImage String? // Base64 or URL

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, staffId, date])
  @@index([schoolId])
  @@index([staffId])
  @@index([date])
}

model Fee {
  id            String   @id @default(cuid())
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id])
  term          String
  year          Int
  amount        Float
  discount      Float    @default(0)
  vatPercentage Float    @default(0)
  paid          Float    @default(0)
  dueDate       DateTime
  status        String   @default("unpaid") // paid, partial, unpaid, overdue
  description   String?
  isLedger      Boolean  @default(false)

