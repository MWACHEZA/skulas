  gradedAt     DateTime?
  schoolId     String
  school       School     @relation(fields: [schoolId], references: [id])

  @@unique([assignmentId, studentId])
  @@index([schoolId])
  @@index([assignmentId])
  @@index([studentId])
}

model News {
