model StudentWallet {
  id        String   @id @default(cuid())
  studentId String   @unique
  student   Student  @relation(fields: [studentId], references: [id])
  balance   Float    @default(0.0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions WalletTransaction[]
}

model WalletTransaction {
  id          String        @id @default(cuid())
  walletId    String
  wallet      StudentWallet @relation(fields: [walletId], references: [id])
  amount      Float
  type        String // 'DEPOSIT', 'PURCHASE', 'REFUND'
  description String?
  createdAt   DateTime      @default(now())

  // Optional reference to a specific sale or receipt
  referenceId   String?
  referenceType String? // e.g. 'TUCKSHOP_SALE', 'UNIFORM_SALE'
}

/// Atomic counter table used by generateSequentialId to guarantee unique sequential IDs.
/// Each row represents one entity type per school (or global for schoolId = '__GLOBAL__').
/// The `lastValue` field is incremented atomically, eliminating the select-then-insert
/// race condition that the old findFirst+orderBy approach suffered from.
model SchoolSequence {
  id        String @id @default(cuid())
  schoolId  String // '__GLOBAL__' for global entities (Supplier, Parent)
  entity    String // 'STUDENT', 'TEACHER', 'APPLICATION', 'BURSAR', etc.
  lastValue Int    @default(0)

  @@unique([schoolId, entity])
}
