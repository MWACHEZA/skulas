  actorId    String
  actor      User     @relation(fields: [actorId], references: [id])
  action     String // e.g. "CREATE_REQUISITION", "UPDATE_GRADE"
  entityType String // e.g. "Requisition", "Grade"
  entityId   String?
  details    Json?
  ipAddress  String?
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id])
