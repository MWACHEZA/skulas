model TuckshopItem {
  id        String         @id @default(cuid())
  name      String
  category  String // Uniform, Stationery, Snack, Drink
  price     Float
  stock     Int            @default(0)
  schoolId  String
  school    School         @relation(fields: [schoolId], references: [id])
  sales     TuckshopSale[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([schoolId])
}

model TuckshopSale {
  id          String       @id @default(cuid())
  itemId      String
  item        TuckshopItem @relation(fields: [itemId], references: [id])
  quantity    Int
  totalAmount Float
  soldAt      DateTime     @default(now())
  studentId   String? // Optional: link to student if recorded
  schoolId    String

  @@index([schoolId])
}

// ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚Â ACADEMIC CONTENT ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚Â

model DigitalResource {
  id          String   @id @default(cuid())
  title       String
  description String?
  fileUrl     String
  fileType    String // PDF, Video, Link, Doc
  category    String // Syllabus, Lecture Note, Past Paper
  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id])
  schoolId    String
  createdAt   DateTime @default(now())

  @@index([teacherId])
  @@index([subjectId])
}

model Syllabus {
  id        String @id @default(cuid())
  schoolId  String
  classId   String
  subjectId String
  topic     String
  content   String
  week      String

  class   SchoolClass @relation(fields: [classId], references: [id])
  subject Subject     @relation(fields: [subjectId], references: [id])
  school  School      @relation(fields: [schoolId], references: [id])

  lessonPlans LessonPlan[]

  createdAt DateTime @default(now())

  @@index([classId])
  @@index([subjectId])
}

model LessonPlan {
  id         String @id @default(cuid())
  schoolId   String
  classId    String
  subjectId  String
  syllabusId String
  teacherId  String

  week    String
  session String
  content String // TOPIC/CONTENT breakdown

  class    SchoolClass @relation(fields: [classId], references: [id])
  subject  Subject     @relation(fields: [subjectId], references: [id])
  syllabus Syllabus    @relation(fields: [syllabusId], references: [id], onDelete: Cascade)
  teacher  Teacher     @relation(fields: [teacherId], references: [id])
  school   School      @relation(fields: [schoolId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teacherId])
  @@index([subjectId])
  @@index([classId])
  @@index([syllabusId])
}

// ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚Â HR / PAYROLL / ROSTERS ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚Â

model SalaryStub {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  month      Int
  year       Int
  basicPay   Float
  allowances Float     @default(0)
  deductions Float     @default(0)
  netPay     Float
  status     String    @default("draft") // draft, paid
  paidAt     DateTime?
  schoolId   String
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([schoolId])
}

model ShiftAssignment {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  dayOfWeek Int // 0=Sun ... 6=Sat
  startTime String // "06:00"
  endTime   String // "14:00"
  location  String?
  task      String?
  schoolId  String

  @@index([userId])
  @@index([schoolId])
}

// ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚Â APPLICANT PORTAL DEPTH ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚Â

model ApplicantDocument {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  name          String // e.g. "Birth Certificate"
  url           String
  status        String      @default("pending") // pending, verified, rejected
  createdAt     DateTime    @default(now())

  @@index([applicationId])
}

model ApplicantTimeline {
  id            String      @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  event         String // Application Submitted, Interview Scheduled, Accepted
  description   String?
  occurredAt    DateTime    @default(now())

  @@index([applicationId])
}

// --- ACADEMIC REPORTING ---

model AcademicReport {
  id               String   @id @default(cuid())
  studentId        String
  student          User     @relation(fields: [studentId], references: [id])
  term             String // Term 1, Term 2, Term 3
  year             String // e.g. "2024"
  data             Json // Snapshot of grades, attendance, comments
  publishedStudent Boolean  @default(false)
  publishedParent  Boolean  @default(false)
  schoolId         String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([studentId])
  @@index([schoolId])
}

model ReportTemplate {
  id           String   @id @default(cuid())
  schoolId     String   @unique
  school       School   @relation(fields: [schoolId], references: [id])
  config       Json // Branding colors, section toggles
  signatureUrl String? // Principal/Headmaster signature
  updatedAt    DateTime @updatedAt
}

// ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚Â REQUISITION FLOW ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚Â

model Requisition {
  id              String  @id @default(cuid())
  refNumber       String  @unique // e.g., PRQ-2024-001
  title           String
  description     String?
  estimatedAmount Float
  status          String  @default("PENDING") // PENDING, HOD_APPROVED, BURSAR_APPROVED, APPROVED, REJECTED

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  requesterId String
  requester   User   @relation("RequisitionRequester", fields: [requesterId], references: [id])

  hodId String?
  hod   User?   @relation("RequisitionHOD", fields: [hodId], references: [id])

  bursarId String?
  bursar   User?   @relation("RequisitionBursar", fields: [bursarId], references: [id])

  adminId String?
  admin   User?   @relation("RequisitionAdmin", fields: [adminId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  purchaseOrderId String?        @unique
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
}

// ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚Â ANCILLARY SERVICES ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚Â

model Hostel {
  id          String  @id @default(cuid())
  name        String
  type        String  @default("BOYS")
  capacity    Int
  location    String?
  description String?

  categoryId String?
  category   HostelCategory? @relation(fields: [categoryId], references: [id])

  roomId   String?
  roomType HostelRoom? @relation(fields: [roomId], references: [id])

  schoolId  String
  school    School    @relation(fields: [schoolId], references: [id])
  rooms     Room[]
  students  Student[]
  createdAt DateTime  @default(now())

  @@index([schoolId])
}

model Room {
  id        String    @id @default(cuid())
  name      String // Room Number/Name
  capacity  Int
  hostelId  String
  hostel    Hostel    @relation(fields: [hostelId], references: [id])
  students  Student[]
  createdAt DateTime  @default(now())

  @@index([hostelId])
}

model BoardingLog {
  id             String    @id @default(cuid())
  studentId      String
  student        Student   @relation(fields: [studentId], references: [id])
  type           String // SIGN_OUT, SIGN_IN, SICK_BAY, DISCIPLINE
  reason         String?
  authorizedById String
  authorizedBy   User      @relation(fields: [authorizedById], references: [id])
  timestamp      DateTime  @default(now())
  returnedAt     DateTime?
  schoolId       String

  @@index([studentId])
  @@index([schoolId])
}

model VisitorLog {
  id          String    @id @default(cuid())
  name        String
  phone       String
  idCard      String?
  numOfPerson Int       @default(1)
  meetingWith String?
  note        String?
  purpose     String
  vehicleReg  String?
  entryTime   DateTime  @default(now())
  exitTime    DateTime?
  guardId     String?
  guard       User?     @relation(fields: [guardId], references: [id])
  schoolId    String

  @@index([schoolId])
}

model AdmissionInquiry {
  id               String       @id @default(cuid())
  name             String
  phone            String
  source           String
  classId          String?
  class            SchoolClass? @relation(fields: [classId], references: [id])
  inquiryDate      DateTime     @default(now())
  lastFollowUpDate DateTime?
  nextFollowUpDate DateTime?
  status           String       @default("Active")
  schoolId         String

  @@index([schoolId])
}

model PhoneCallLog {
  id               String    @id @default(cuid())
  name             String
  phone            String
  date             DateTime  @default(now())
  nextFollowUpDate DateTime?
  callDuration     String?
  callType         String // incoming or outgoing
  description      String?
  schoolId         String

  @@index([schoolId])
}

model FrontOfficeComplaint {
  id           String   @id @default(cuid())
  complainType String
  source       String
  complainBy   String
  phone        String
  date         DateTime @default(now())
  actionTaken  String?
  assignedTo   String?
  description  String?
  schoolId     String

  @@index([schoolId])
}

model SecurityIncident {
  id           String   @id @default(cuid())
  title        String
  description  String
  severity     String   @default("LOW") // LOW, MEDIUM, HIGH, CRITICAL
  location     String?
  reportedById String
  reportedBy   User     @relation(fields: [reportedById], references: [id])
  timestamp    DateTime @default(now())
  schoolId     String

  @@index([schoolId])
}

model WeeklyMenu {
  id           String   @id @default(cuid())
  weekStarting DateTime
  menuData     Json // { monday: { breakfast: "", lunch: "", dinner: "" }, ... }
  published    Boolean  @default(false)
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model TransferAuthorization {
  id             String @id @default(cuid())
  studentUserId  String
  studentUser    User   @relation("StudentTransfers", fields: [studentUserId], references: [id])
  originSchoolId String
  originSchool   School @relation("OriginTransfers", fields: [originSchoolId], references: [id])
  targetSchoolId String
  targetSchool   School @relation("TargetTransfers", fields: [targetSchoolId], references: [id])

  studentConsent Boolean @default(false)
  originConsent  Boolean @default(false)
  targetConsent  Boolean @default(false)

  status String @default("PENDING") // PENDING, APPROVED, REJECTED, EXPIRED

  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentUserId, originSchoolId, targetSchoolId])
  @@index([studentUserId])
  @@index([originSchoolId])
  @@index([targetSchoolId])
}

// ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚Â POSTGRADUATE & RESEARCH ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚Â

model SupervisorAssignment {
  id         String   @id @default(cuid())
  studentId  String
  student    Student  @relation(fields: [studentId], references: [id])
  teacherId  String
  teacher    Teacher  @relation(fields: [teacherId], references: [id])
  role       String   @default("PRINCIPAL") // PRINCIPAL, CO_SUPERVISOR, ASSOCIATE
  assignedAt DateTime @default(now())

  progressReports ProgressReport[]
  schoolId        String
  school          School           @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, studentId, teacherId])
  @@index([schoolId])
  @@index([studentId])
  @@index([teacherId])
}

model ExtensionRequest {
  id                String  @id @default(cuid())
  studentId         String
  student           Student @relation(fields: [studentId], references: [id])
  reason            String
  durationRequested Int // In months
  justificationUrl  String? // Optional attachment
  status            String  @default("PENDING") // PENDING, APPROVED, REJECTED
  adminComment      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([studentId])
}

model ProgressReport {
  id           String               @id @default(cuid())
  studentId    String
  student      Student              @relation(fields: [studentId], references: [id])
  assignmentId String
  assignment   SupervisorAssignment @relation(fields: [assignmentId], references: [id])

  reportPeriod   String // e.g. "Jan-Jun 2024"
  content        String // Research progress details
  status         String  @default("SUBMITTED") // SUBMITTED, SATISFACTORY, UNSATISFACTORY, RE_SUBMIT
  supervisorNote String?

  submittedAt DateTime  @default(now())
  reviewedAt  DateTime?
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([studentId])
  @@index([assignmentId])
}

// ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚Â FINANCIAL CONFIGURATIONS ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚Â

model PaymentMethod {
  id        String   @id @default(cuid())
  name      String // e.g. "ZB Bank", "USD Cash", "Ecocash"
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
}

model FeeGroup {
  id               String  @id @default(cuid())
  name             String // Fee Group Title (e.g. "Tuition", "Transport")
  amount           Float // Cost $
  year             Int // Billing Year
  billingType      String // Billing Type / Period (Once Off, Term 1, January, etc.)
  isRecurring      Boolean @default(false)
  remindersEnabled Boolean @default(false)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])
  fees     Fee[]

  revenueAllocations RevenueAllocation[]   @relation("AllocatedFeeGroups")
  classAmounts       FeeGroupClassAmount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name, year, billingType])
  @@index([schoolId])
}

model FeeGroupClassAmount {
  id         String      @id @default(cuid())
  feeGroupId String
  feeGroup   FeeGroup    @relation(fields: [feeGroupId], references: [id], onDelete: Cascade)
  classId    String
  class      SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  amount     Float

  @@unique([feeGroupId, classId])
}

model PhysicalProduct {
  id       String @id @default(cuid())
  name     String
  unit     String // Kg, Liters, etc.
  quantity Float  @default(0) // Current Stock
  price    Float  @default(0) // Cost per unit if billable

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  consumptions PhysicalProductConsumption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
}

model PhysicalProductConsumption {
  id           String          @id @default(cuid())
  productId    String
  product      PhysicalProduct @relation(fields: [productId], references: [id])
  quantity     Float
  requestedBy  String
  dispatchedBy String?
  date         DateTime

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([productId])
}

model FeeReminderLog {
  id          String   @id @default(cuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  source      String // e.g. "GENERAL_BATCH", "PAYMENT_PLAN"
  status      String // SENT, FAILED
  retries     Int      @default(0)
  lastAttempt DateTime @default(now())
  error       String?

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt DateTime @default(now())

  @@index([studentId])
}

model StudentPayment {
  id        String  @id @default(cuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id])
  feeId     String?
  fee       Fee?    @relation(fields: [feeId], references: [id])

  amount      Float
  paymentMode String // e.g. "USD Cash", "ZB Bank", "Ecocash"
  reference   String? // Receipt number or transaction ref
  status      String   @default("Commit") // Commit, Refunded, Pending
  date        DateTime @default(now())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([studentId])
  @@index([feeId])
}

model CommunicationLog {
  id        String   @id @default(cuid())
  type      String // WhatsApp, Email
  senderId  String
  sender    User     @relation("CommunicationSender", fields: [senderId], references: [id])
  studentId String?
  student   Student? @relation(fields: [studentId], references: [id])

  description   String // e.g. "Account Statement Email For Sydney"
  status        String  @default("Sent") // Sent, Delivered, Read, Failed
  providerMsgId String? // Meta WhatsApp Message ID or SES Message ID
  errorDetails  String? // Reason for failure

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([schoolId])
  @@index([studentId])
  @@index([senderId])
  @@index([providerMsgId])
}

model NotificationQueue {
  id             String   @id @default(cuid())
  type           String // WhatsApp, Email, SMS
  recipientPhone String?
  recipientEmail String?
  template       String? // Template name or subject
  payload        String // JSON content for the notification
  status         String   @default("PENDING") // PENDING, PROCESSING, FAILED, COMPLETED
  retries        Int      @default(0)
  nextAttempt    DateTime @default(now())
  errorDetails   String?

  senderId  String
  schoolId  String
  studentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId, status, nextAttempt])
}

model RevenueAllocation {
  id         String  @id @default(cuid())
  name       String // e.g. "Main Allocation 2025"
  schoolYear Int
  period     String // Term 1, Term 2, etc.
  isActive   Boolean @default(true)

  // Breakdown of where the money goes
  // [{ label: "Wages", percentage: 60 }, { label: "Infrastructure", percentage: 10 }]
  breakdown Json

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  // Which fee groups this allocation applies to
  feeGroups FeeGroup[] @relation("AllocatedFeeGroups")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
}

// ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚Â PAYROLL & EMPLOYEE MANAGEMENT ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚Â

model PayrollAllowance {
  id           String   @id @default(cuid())
  name         String
  isRecurring  Boolean  @default(false)
  isPercentage Boolean  @default(false)
  defaultValue Float    @default(0)
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
}

model PayrollDeduction {
  id           String   @id @default(cuid())
  name         String
  isRecurring  Boolean  @default(false)
  isPercentage Boolean  @default(false)
  defaultValue Float    @default(0)
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
}

model TaxTable {
  id            String    @id @default(cuid())
  name          String
  region        String?
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive      Boolean   @default(true)
  schoolId      String
  school        School    @relation(fields: [schoolId], references: [id])
  bands         TaxBand[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([schoolId])
}

model TaxBand {
  id          String   @id @default(cuid())
  taxTableId  String
  taxTable    TaxTable @relation(fields: [taxTableId], references: [id], onDelete: Cascade)
  minIncome   Float
  maxIncome   Float?
  rate        Float // Percentage
  fixedAmount Float    @default(0)
  schoolId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId])
}

model EmployeeProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobTitle     String?
  basePay      Float    @default(0)
  payFrequency String   @default("MONTHLY") // DAILY, WEEKLY, FORTNIGHTLY, MONTHLY, ANNUALLY
  contractType String? // Permanent, Contract, etc.
  hireDate     DateTime @default(now())

  // New HR/Payroll Fields
  bloodGroup        String?
  dateAssumedPost   DateTime? @default(now())
  dateOfLeaving     DateTime?
  designation       String? // Redundant with jobTitle but requested
  accountNumber     String?
  accountHolderName String?
  bankName          String?
  bankBranch        String?
  branchCode        String?
  accountType       String?

  // ZiG Banking Fields
  accountNumberZig     String?
  accountHolderNameZig String?
  bankNameZig          String?
  bankBranchZig        String?
  branchCodeZig        String?
  accountTypeZig       String?

  // Social Links
  facebookLink String?
  linkedinLink String?
  twitterLink  String?

  // Documents Tracking (Links to stored files)
  staffDocuments Json? // { residence: "path", id: "path", qualifications: ["path1", "path2"] }

  status    String   @default("Active") // Active, Inactive, Terminated
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
}

model TermlyComment {
  id        String  @id @default(cuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id])
  term      String
  year      Int

  classTeacherComment String?
  principalComment    String?

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, studentId, term, year])
  @@index([schoolId])
  @@index([studentId])
}

model PayrollRun {
  id              String   @id @default(cuid())
  month           Int
  year            Int
  runDate         DateTime @default(now())
  status          String   @default("Completed") // Draft, Completed
  frequency       String   @default("Monthly")
  employeesCount  Int
  totalGross      Float
  totalDeductions Float
  totalNet        Float

  schoolId String
  school   School         @relation(fields: [schoolId], references: [id])
  entries  PayrollEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, month, year])
  @@index([schoolId])
}

model PayrollEntry {
  id           String     @id @default(cuid())
  payrollRunId String
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeName String
  jobTitle     String?

  grossSalary     Float
  totalAllowances Float
  totalDeductions Float
  taxAmount       Float
  aidsLevy        Float   @default(0)
  netSalary       Float
  isPaid          Boolean @default(false)

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([payrollRunId])
  @@index([userId])
}

// ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚Â CBT (Computer Based Test) ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚ÂÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚Â

model CBTExam {
  id             String       @id @default(cuid())
  title          String
  description    String?
  date           DateTime
  time           String
  passingPercent Float        @default(50)
  totalMarks     Float        @default(0)
  status         String       @default("Pending") // Pending, Active, Expired
  classId        String?
  class          SchoolClass? @relation(fields: [classId], references: [id])
  sectionId      String?
  section        Section?     @relation(fields: [sectionId], references: [id])
  subjectId      String
  subject        Subject      @relation(fields: [subjectId], references: [id])
  schoolId       String
  school         School       @relation(fields: [schoolId], references: [id])
  teacherId      String?

  questions CBTQuestion[]
  results   CBTResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([subjectId])
}

model CBTQuestion {
  id       String  @id @default(cuid())
  examId   String
  exam     CBTExam @relation(fields: [examId], references: [id], onDelete: Cascade)
  type     String // "Single choice", "Multiple choice", "True or false", "Fill in the blanks"
  mark     Float   @default(1)
  question String  @db.Text
  options  Json? // Array of option strings
  answer   Json // Array of correct option strings or true/false

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CBTResult {
  id         String  @id @default(cuid())
  examId     String
  exam       CBTExam @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId  String
  score      Float
  totalMarks Float
  status     String // Pass, Fail
  responses  Json? // Student's answers

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([examId, studentId])
}

model LiveClass {
  id        String      @id @default(cuid())
  schoolId  String
