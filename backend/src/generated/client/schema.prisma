  startTime   String // "07:30"
  endTime     String
  room        String?
  term        String      @default("Term 1")
  year        Int         @default(2025)
  isPublished Boolean     @default(false)

  @@index([classId])
  @@index([schoolId])
}

model Announcement {
  id             String    @id @default(cuid())
  title          String
  content        String
  targetRole     String    @default("ALL") // Deprecated in favor of visiblePortals
  visiblePortals String[]  @default(["ALL"])
  isPublic       Boolean   @default(false)
  schoolId       String
  school         School    @relation(fields: [schoolId], references: [id])
  publishedAt    DateTime  @default(now())
  expiresAt      DateTime?

  @@index([schoolId])
}

