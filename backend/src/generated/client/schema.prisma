model TimetableSlot {
  id          String      @id @default(cuid())
  classId     String
  class       SchoolClass @relation(fields: [classId], references: [id])
  subjectId   String
  subject     Subject     @relation(fields: [subjectId], references: [id])
  schoolId    String
