model Asset {
  id            String    @id @default(cuid())
  name          String
  category      String // furniture, electronics, vehicles, stationery
  serialNumber  String?
  location      String?
  condition     String    @default("good") // good, fair, poor, condemned
  purchaseDate  DateTime?
  purchasePrice Float?

  custodianId String?
  custodian   User?   @relation("AssetCustodian", fields: [custodianId], references: [id])

  schoolId String
  school   School @relation(fields: [schoolId], references: [id])

  incidents   AssetIncident[]
  maintenance AssetMaintenance[]

  nextMaintenance     DateTime?
  maintenanceInterval Int? // Interval in days
  attachments         Json? // [{name, url}] for receipts/warranties

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([custodianId])
}

model AssetIncident {
  id         String @id @default(cuid())
  assetId    String
  asset      Asset  @relation(fields: [assetId], references: [id])
  reporterId String
  reporter   User   @relation("IncidentReporter", fields: [reporterId], references: [id])

  issueType String // general, hardware, usage, theft
  details   String
  status    String @default("PENDING") // PENDING, RESOLVED

  resolvedBy  String?
  fixDetails  String?
  attachments Json? // [{name, url}] for proof of incident/fix

  schoolId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
  @@index([reporterId])
}

model AssetMaintenance {
  id      String @id @default(cuid())
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  scheduledDate DateTime
  performedDate DateTime?
  description   String
  attachments   Json? // [{name, url}] for proof of work
  cost          Float?

  schoolId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
}

