model Application {
  id                String    @id @default(cuid())
  applicationNumber String?   @unique // APP-AX-CODE-260001
  applicantName     String
  email             String
  phone             String?
  dob               DateTime?
  gender            String?
  appType           String    @default("Form 1") // Form 1, A-Level, Transfer
  status            String    @default("pending") // pending, accepted, rejected, waitlisted, review, interview

  // Interview Details (Legacy Flow)
  interviewDate  DateTime?
  interviewTime  String?
  interviewVenue String?

  // Transfer & Academic History
  prevSchool        String?
  reasonForTransfer String?
  lastGradeAchieved String?
  academicHistory   Json? // [{subject, grade}] - Legacy format
  academicData      Json? // Structured O/A level data for Universities
  entryCategory     String? // Normal, Special, Mature

  // Postgraduate Fields
  programLevel  String? // PG_DIPLOMA, MASTERS_TAUGHT, etc.
  studyMode     String? // FULL_TIME, PART_TIME
  researchTitle String?

