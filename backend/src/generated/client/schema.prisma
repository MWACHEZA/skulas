  @@index([schoolId])
  @@index([actorId])
}

model Book {
  id            String    @id @default(cuid())
  title         String
  author        String
  isbn          String?
  edition       String?
  publisher     String?
  price         Float?
  publishedDate DateTime?
  description   String?
  status        String    @default("Available")

  categoryId String?
  category   LibraryCategory? @relation(fields: [categoryId], references: [id])

  subjectId String?
  subject   Subject? @relation(fields: [subjectId], references: [id])

